<script>
        var CLIPBOARD = null;

    $(function () {
        $("#examLevelTreePanel")
            .fancytree({
                checkbox: true,
                checkboxAutoHide: false,
                selectMode: 1,
                rtl: true,
                titlesTabbable: true,
                quicksearch: true,
                extensions: ["edit", "dnd5", "table", "gridnav"],
                dnd5: {
                    preventVoidMoves: true,
                    preventRecursion: true,
                    autoExpandMS: 400,
                    dragStart: function (node, data) {
                        return true;
                    },
                    dragEnter: function (node, data) {
                        return true;
                    },
                    dragDrop: function (node, data) {
                        if ((node.type == 2 && data.otherNodeData.type == 1) || (node.type == 1 && data.otherNodeData.type == 2 && data.hitMode != "over") || (node.type == 1 && data.otherNodeData.type == 1 && data.hitMode == "over") || (node.type == 2 && data.otherNodeData.type == 2 && data.hitMode == "over")) {
                            return false;
                        }
                        data.otherNode.moveTo(node, data.hitMode);
                        var scope = angular.element(document.getElementById('mainWrap')).scope();
                        scope.safeApply(function () {
                            scope.CorrectQuestionOrders();
                            scope.UpdateModelByTreePanel();
                            scope.ReloadTreePanel();
                        });
                    },
                },
                edit: {
                    triggerStart: ["f2", "shift+click", "mac+enter"],
                    close: function (event, data) {
                        if (data.save && data.isNew) {
                            // Quick-enter: add new nodes until we hit [enter] on an empty title
                            $("#examLevelTreePanel").trigger("nodeCommand", {
                                cmd: "addSibling",
                            });
                            var scope = angular.element(document.getElementById('mainWrap')).scope();
                            scope.safeApply(function () {
                                scope.UpdateModelByTreePanel();
                                scope.NewId += 1;
                                scope.UpdateQuestionExamCourses();
                            });
                        }
                        else if (data.save) {
                            var scope = angular.element(document.getElementById('mainWrap')).scope();
                            scope.safeApply(function () {
                                scope.UpdateModelByTreePanel();
                                scope.UpdateQuestionExamCourses();
                            });
                        }
                    },
                },
                table: {
                    indentation: 20,
                    nodeColumnIdx: 1,
                    checkboxColumnIdx: 0,
                },
                gridnav: {
                    autofocusInput: false,
                    handleCursorKeys: true,
                },

                createNode: function (event, data) {

                    var node = data.node,
                        $tdList = $(node.tr).find(">td");
                    $tdList
                        .eq(1)
                        .find("input")
                        .val(node.data.title);
                    $tdList
                        .eq(2)
                        .find("span")
                        .html(node.data.questionCount);
                    $tdList
                        .eq(3)
                        .find("span")
                        .html(node.data.from);
                    $tdList
                        .eq(4)
                        .find("span")
                        .html(node.data.to);
                    if (node.type == 1) {
                        $tdList
                            .eq(0)
                            .html('');
                    }
                },
                renderColumns: function (event, data) {
                    var node = data.node,
                        $tdList = $(node.tr).find(">td");

                    $tdList
                        .eq(1)
                        .find("input")
                        .val(node.data.title);

                    $tdList
                        .eq(2)
                        .find("span")
                        .html(node.data.questionCount);
                    $tdList
                        .eq(3)
                        .find("span")
                        .html(node.data.from);
                    $tdList
                        .eq(4)
                        .find("span")
                        .html(node.data.to);
                    if (node.type == 1) {
                        $tdList
                            .eq(0)
                            .html('');
                    }
                },
                modifyChild: function (event, data) {
                    data.tree.info(event.type, data);
                },
                activate: function (event, data) {
                    var node = data.node;
                    if (node.type != undefined) {
                        if (node.type == 2) {
                            //FT.debug("activate: event=", event, ", data=", data);
                            if (!$.isEmptyObject(node.data)) {
                                //  alert("custom node data: " + JSON.stringify(node.data));
                            }

                        }
                    }

                },
                init: function (event, data) {
                },
            })
            .on("nodeCommand", function (event, data) {

                var newId = 1;
                var scope = angular.element(document.getElementById('mainWrap')).scope();
                scope.safeApply(function () {
                    newId = scope.NewId;
                });

                var refNode,
                    moveMode,
                    tree = $(this).fancytree("getTree"),
                    node = tree.getActiveNode();

                switch (data.cmd) {
                    case "addSibling":
                        if (node.parent.parent != null) {
                            return false;
                        }
                        node.editCreateNode("after", {
                            title: "",
                            folder: node.parent.parent == null ? true : false,
                            coefficient: 1,
                            from: 0,
                            to: 0,
                            type: 1,
                            children: [],
                            subGroups: [],
                            questions: [],
                            coefficients: [],
                            id: newId
                        });

                        break;
                    case "addChild":
                        if (node.parent.parent != null) {
                            //alert("درس باید به عنوان زیرمجموعه گروه اصلی باشد");
                            return false;
                        }
                        node.editCreateNode("child", {
                            title: "",
                            folder: false,
                            coefficient: 1,
                            from: 0,
                            to: 0,
                            subGroups: [],
                            questions: [],
                            coefficients: [],
                            type: 2,
                            id: newId
                        });

                        break;

                    case "indent":
                    case "moveDown":
                    case "moveUp":
                    case "outdent":
                    case "remove":
                        var isGroup = node.parent.parent == null ? true : false;
                        if (isGroup) {
                            if (node.data.isMainNode) {
                                swal({ text: 'امکان حذف گروپیش فرض وجود ندارد', icon: "error", button: "باشه" });
                                return false;
                            }
                        }
                        scope.safeApply(function () {
                            scope.RemoveNodeFromModelPanel(data, node/* isGroup, node.parent.data.id, node.data.id*/);
                            //tree.applyCommand(data.cmd, node);

                        });
                        break;
                    case "rename":
                        tree.applyCommand(data.cmd, node);
                        break;
                    case "cut":
                        CLIPBOARD = { mode: data.cmd, data: node };
                        break;
                    case "copy":
                        CLIPBOARD = {
                            mode: data.cmd,
                            data: node.toDict(function (n) {
                                delete n.key;
                            }),
                        };
                        break;
                    case "clear":
                        CLIPBOARD = null;
                        break;
                    case "paste":
                        if (CLIPBOARD.mode === "cut") {
                            // refNode = node.getPrevSibling();
                            CLIPBOARD.data.moveTo(node, "child");
                            CLIPBOARD.data.setActive();
                        } else if (CLIPBOARD.mode === "copy") {
                            node.addChildren(
                                CLIPBOARD.data
                            ).setActive();
                        }
                        break;
                    default:
                        alert("Unhandled command: " + data.cmd);
                        return;
                }
            })

        $("#examLevelTreePanel").contextmenu({
            delegate: "span.fancytree-node",
            zIndex: 10000000,
            menu: [
                {
                    title: "ویرایش",
                    cmd: "rename",
                    uiIcon: "ui-icon-pencil",
                },
                {
                    title: "حذف",
                    cmd: "remove",
                    uiIcon: "ui-icon-trash",
                },
                { title: "----" },
                {
                    title: "گروه جدید",
                    cmd: "addSibling",
                    uiIcon: "ui-icon-plus",
                },
                {
                    title: "درس جدید",
                    cmd: "addChild",
                    uiIcon: "ui-icon-arrowreturn-1-e",
                },
                //{
                //    title: "درس جدید با زیرگروه",
                //    cmd: "addChildWithSubGroups",
                //    uiIcon: "ui-icon-arrowreturn-1-e",
                //},
                //{ title: "----" },
                //{
                //    title: "برش",
                //    cmd: "cut",
                //    uiIcon: "ui-icon-scissors",
                //},
                //{
                //    title: "کپی",
                //    cmd: "copy",
                //    uiIcon: "ui-icon-copy",
                //},
                //{
                //    title: "چسباندن  به عنوان زیرمجموعه",
                //    cmd: "paste",
                //    uiIcon: "ui-icon-clipboard",
                //    disabled: true,
                //},
            ],
            beforeOpen: function (event, ui) {
                var node = $.ui.fancytree.getNode(ui.target);
                $("#examLevelTreePanel").contextmenu(
                    "enableEntry",
                    "paste",
                    !!CLIPBOARD
                );
                node.setActive();
            },
            select: function (event, ui) {
                var that = this;
                // delay the event, so the menu can close and the click event does
                // not interfere with the edit control
                setTimeout(function () {
                    $(that).trigger("nodeCommand", { cmd: ui.cmd });
                }, 100);
            }
        });

    })

    $(window).on("load", function () {
        var scope = angular.element(document.getElementById('mainWrap')).scope();
        scope.safeApply(function () {
            scope.LoadTreeData();
        });
    })
</script>
    



